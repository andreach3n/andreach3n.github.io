---
// BaseLayout — the shared HTML shell for every page.
//
// Two-column layout, inspired by joneedssleep.github.io:
//   - a big page TITLE parked on the left. It sits in the SAME spot on
//     every page (right under the nav) — only its text changes, so
//     navigating feels like the title stays put and the content swaps.
//   - the page CONTENT flows in the right column (the <slot />).
//   - small nav tabs live in the upper-right corner.
//
// Props:
//   title    -> the document <title> (browser tab)
//   heading  -> the big visible title in the left column
//   home     -> the landing page. Hides the small name link up top
//               (the big left title already shows the name).
import '../styles/global.css';

interface Props {
	title: string;
	heading: string;
	description?: string;
	home?: boolean;
}

const {
	title,
	heading,
	description = 'Andrea Chen’s personal website.',
	home = false,
} = Astro.props;

// The "about" tab and the name both point home (/) — same page.
const navLinks = [
	{ href: '/', label: 'about' },
	{ href: '/projects', label: 'projects' },
	{ href: '/writing', label: 'writing' },
	{ href: '/now', label: 'now' },
];

const path = Astro.url.pathname;
const isCurrent = (href: string) =>
	href === '/' ? path === '/' : (path === href || path.startsWith(href + '/'));
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>

		<!-- Display font for the name + titles -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600&display=swap"
			rel="stylesheet"
		/>
	</head>

	<body>
		<header class="top">
			{!home && <a class="brand" href="/">Andrea Chen</a>}
			<nav>
				{navLinks.map((link) => (
					<a
						href={link.href}
						aria-current={isCurrent(link.href) ? 'page' : undefined}
					>
						{link.label}
					</a>
				))}
			</nav>
		</header>

		<div class="container">
			<div class="left-column">
				<h1 class="page-title">{heading}</h1>
			</div>
			<div class="right-column">
				<slot />
			</div>
		</div>

		<!-- KaTeX: renders LaTeX anywhere on the site. Write inline math
		     between $…$ (or \( …\)) and display math between $$…$$.
		     Note: inside JS strings (like the projects `details` arrays),
		     backslashes must be doubled: '$\\pi$' not '$\pi$'. -->
		<script>
			import 'katex/dist/katex.min.css';
			import renderMathInElement from 'katex/dist/contrib/auto-render.mjs';
			renderMathInElement(document.body, {
				delimiters: [
					{ left: '$$', right: '$$', display: true },
					{ left: '$', right: '$', display: false },
					{ left: '\\(', right: '\\)', display: false },
					{ left: '\\[', right: '\\]', display: true },
				],
				throwOnError: false,
			});
		</script>
	</body>
</html>

<style>
	.top {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		padding: 1.5rem 2rem;
	}
	.brand {
		font-family: var(--font-display);
		font-size: 1.05rem;
		color: var(--ink);
	}
	.brand:hover { text-decoration: none; color: var(--accent); }

	nav {
		margin-left: auto; /* pin tabs right even when the brand is hidden */
		display: flex;
		gap: 1.4rem;
		flex-wrap: wrap;
	}
	nav a {
		color: var(--muted);
		font-size: 0.95rem;
	}
	nav a:hover { color: var(--ink); text-decoration: none; }
	nav a[aria-current='page'] {
		color: var(--ink);
		border-bottom: 1.5px solid var(--accent);
	}

	/* Two-column body. The left title starts at the same y on every page. */
	.container {
		max-width: 1040px;
		margin: 0 auto;
		padding: 3rem 2rem 5rem;
		display: flex;
		align-items: flex-start;
		gap: 3rem;
	}
	.left-column {
		flex: 0 0 clamp(200px, 26vw, 300px);
	}
	.page-title {
		font-size: clamp(2.2rem, 4.5vw, 3rem);
		margin: 0;
		position: sticky;
		top: 3rem; /* keeps the title in view as long content scrolls */
	}
	.right-column {
		flex: 1 1 auto;
		min-width: 0;
		max-width: 60ch;
		padding-top: 0.4rem; /* optically align first line with the title */
	}
	.right-column :global(> :first-child) { margin-top: 0; }

	/* Stack on narrow screens: title on top, content below. */
	@media (max-width: 720px) {
		.top { padding: 1.1rem 1.25rem; gap: 0.75rem; }
		nav { gap: 1rem; }
		.container {
			flex-direction: column;
			gap: 1.5rem;
			padding: 1.5rem 1.25rem 4rem;
		}
		.left-column { flex: none; }
		.page-title { position: static; }
	}
</style>
