---
// BaseLayout ‚Äî the shared HTML shell for every page.
// Each page passes a `title` (and optional `description`) and its content
// goes into the <slot />. Edit the nav / footer here once and it updates
// everywhere.
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Andrea Chen's personal website." } = Astro.props;

// The links that appear in the top navigation.
const navLinks = [
	{ href: '/', label: 'Home' },
	{ href: '/projects', label: 'Projects' },
	{ href: '/blog', label: 'Blog' },
	{ href: '/resume', label: 'Resume' },
];

// Used to highlight the current page in the nav.
const path = Astro.url.pathname;
const isCurrent = (href: string) =>
	href === '/' ? path === '/' : path.startsWith(href);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>

		<!-- Display font for headings -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<header class="site-nav">
			<a class="brand" href="/">andrea chen</a>
			<nav>
				{navLinks.map((link) => (
					<a
						href={link.href}
						aria-current={isCurrent(link.href) ? 'page' : undefined}
					>
						{link.label}
					</a>
				))}
			</nav>
		</header>

		<main class="wrap">
			<slot />
		</main>

		<footer class="site-footer">
			<p>¬© {new Date().getFullYear()} Andrea Chen ¬∑ built with Astro</p>
		</footer>
	</body>
</html>
