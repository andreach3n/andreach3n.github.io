---
// Projects — a list of titles; clicking one slides open a side panel with
// a longer description (the title column shrinks to make room).
// Add or edit entries in the array below:
//   title   -> the project name (click target)
//   note    -> one quiet line underneath (venue, year, tech, whatever)
//   details -> the panel body, in order. Each item is either a paragraph
//              (a plain string) or a photo (an object { src, alt, caption? }).
//              Mix them freely to scatter photos between paragraphs. Photo
//              files go in public/projects/ (src like '/projects/shot.png').
//   links   -> optional external links at the bottom of the panel, one per
//              line: [{ href: 'https://…', text: 'read the paper →' }, …]
//              (for a single link you can also just use href / linkText.)
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
	{
		title: '"Flipped" Tuned Lens',
		note: 'mechinterp research',
		details: [
			'Ongoing - I keep a log of what I try!',
		],
		links: [
			{ href: '/research-log', text: 'weekly research log →' },
		],
	},
	{
		title: 'Pocket-Pod Sofa',
		note: 'inflatable social sofa :)',
		details: [
			{src: '/projects/sofa1.jpg', alt:'sofa', caption: 'ft. Keira, our model'},
			'more on this soon!'
		],
	},
	{
		title: 'Forming Waves: Mold-Pressed Aluminum',
		note: 'molds, plywood, hydraulic press, deformation',
		details: [
			{src: '/projects/longwave.jpg', alt:'longwave'},
			'more on this soon!'
		],
	},
	{
		title:
			'Necklaces, permutations, and periodic critical orbits for quadratic polynomials',
		note: 'European Journal of Combinatorics, 2026',
		details: [
			"Let $G_n$ denote the nth Gleason polynomial, whose roots correspond to parameters $c$ such that the critical point 0 is periodic of exact period $n$ under iteration of $z^2+c$, and let $\\bar{G}_n$ denote the reduction of $G_n$ modulo 2. Buff, Floyd, Koch, and Parry made the surprising observation that the number of real roots of $G_n$ is equal to the number of irreducible factors of $\\bar{G}_n$ for all $n$.",
			"We provide a bijective proof for this result by first providing explicit bijections between (a) the set of real roots of $G_n$ and the set $\\bar{N}(n)$ of equivalence classes of primitive binary necklaces of length n under the inversion map swapping 0 and 1; and (b) the set of irreducible factors of $G_n$ modulo 2 and the set $\\tilde{N}^+(n)$ of binary necklaces which are either primitive of length n with an even number of 1's or primitive of length n/2 with an odd number of 1's. We then provide an explicit bijection, closely related to Milnor and Thurston's kneading theory, between $\\bar{N}(n)$ and $\\tilde{N}^+(n)$.",
			"In addition, we provide explicit bijections between $\\bar{N}(n)$, the set CUP(n) of cyclic unimodal permutations of $\\{1,\\ldots,n\\}$, and the set $N^-(n)$ of primitive binary necklaces of length n with an odd number of 1's.",
		],
		links: [
			{ href: 'https://www.sciencedirect.com/science/article/pii/S019566982600020X', text: 'read the paper →' },
			{ href: 'https://meetings.ams.org/math/jmm2025/meetingapp.cgi/Paper/40130', text: 'AMS Special Session on Arithmetic Dynamics of Single and Multiple Maps' },
		],
	},
	{
		title: 'Panic! at the Easel',
		note: '1st Place MIT Web.Lab, 2026',
		details: [
			{src: '/projects/panic.png', alt:'game homepage'},
			// a photo can go between paragraphs, like this:
			// { src: '/projects/easel-1.png', alt: 'a screenshot of the game', caption: 'the drawing canvas' },
			// '[filler — more description, picking up after the photo.]',
		],
		href: '[filler - link]',
	},
];
---

<BaseLayout title="projects — Andrea Chen" heading="projects">
	<div class="split" id="split">
		<ul class="projects">
			{projects.map((p, i) => (
				<li>
					<button class="title" data-open={i}>{p.title}</button>
					<p class="dim">{p.note}</p>
				</li>
			))}
		</ul>

		<aside class="panel" aria-label="project details">
			<button class="close" data-close aria-label="close details">&times;</button>
			{projects.map((p, i) => (
				<article class="detail" data-detail={i} hidden>
					<h3>{p.title}</h3>
					<p class="dim">{p.note}</p>
					{p.details?.map((item) =>
						typeof item === 'string' ? (
							<p>{item}</p>
						) : (
							<figure class="shot">
								<img src={item.src} alt={item.alt ?? ''} loading="lazy" />
								{item.caption && <figcaption>{item.caption}</figcaption>}
							</figure>
						)
					)}
					{(p.links ?? (p.href ? [{ href: p.href, text: p.linkText ?? 'link →' }] : [])).map((l) => (
						<p class="link-row"><a href={l.href}>{l.text}</a></p>
					))}
				</article>
			))}
		</aside>
	</div>
</BaseLayout>

<style>
	/* Two columns: titles | detail panel. The panel column is 0 wide until
	   a project is opened; grid-template-columns animates the shrink. */
	.split {
		/* How far the open panel reaches past the normal content column
		   toward the nav's right edge — the container is 1040px max, so the
		   overhang on each side is (100vw - 1040px)/2, clamped to 0 on
		   narrower screens where the content already meets the nav. */
		--reach: max(0px, (100vw - 1040px) / 2);
		display: grid;
		grid-template-columns: 1fr 0fr;
		gap: 0;
		transition: grid-template-columns 0.35s ease, margin-right 0.35s ease;
	}
	.split.open {
		grid-template-columns: 1fr 2fr;
		gap: 2rem;
		margin-right: calc(-1 * var(--reach));
	}

	/* When a panel is open, let the content shed the layout's 60ch reading
	   cap so the titles + wider panel can use the full width. */
	:global(.right-column:has(.split.open)) {
		max-width: none;
	}

	.projects {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1.6rem;
		min-width: 0;
		max-width: 60ch; /* keep the closed title list at a comfortable width */
	}
	.projects p {
		margin: 0.15rem 0 0;
	}

	/* Titles are buttons but dress like the links they used to be. */
	.title {
		all: unset;
		cursor: pointer;
		color: var(--accent);
	}
	.title:hover {
		text-decoration: underline;
		text-underline-offset: 3px;
	}
	.title:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 3px;
		border-radius: 2px;
	}
	.title[aria-expanded='true'] {
		color: var(--ink);
		font-weight: 600;
	}

	/* --- the side panel ---------------------------------------------------- */
	.panel {
		position: relative;
		min-width: 0;
		overflow: hidden; /* lets the column collapse to 0 cleanly */
		opacity: 0;
		transition: opacity 0.3s ease 0.1s;
		border-left: 1px solid var(--line);
		padding-left: 2rem;
		align-self: start;
	}
	.split.open .panel {
		opacity: 1;
	}
	.panel h3 {
		margin: 0 2rem 0.25rem 0; /* leave room for the × */
		font-size: 1.15rem;
	}
	.panel p {
		font-size: 0.95rem;
	}
	/* stacked links sit close together as a little list */
	.link-row {
		margin: 0.35rem 0 0;
	}

	/* photos inside the panel */
	.shot {
		margin: 1.25rem 0;
	}
	.shot img {
		display: block;
		width: 100%;
		height: auto;
		border: 1px solid var(--line);
		border-radius: 4px;
	}
	.shot figcaption {
		margin-top: 0.4rem;
		color: var(--muted);
		font-size: 0.8rem;
		line-height: 1.5;
	}
	.close {
		all: unset;
		cursor: pointer;
		position: absolute;
		top: -0.2rem;
		right: 0.2rem;
		font-size: 1.3rem;
		line-height: 1;
		color: var(--muted);
		padding: 0.2rem 0.4rem;
	}
	.close:hover {
		color: var(--ink);
	}
	.close:focus-visible {
		outline: 2px solid var(--accent);
		border-radius: 2px;
	}

	/* On narrow screens the panel sits below the list instead of beside it. */
	@media (max-width: 720px) {
		.split,
		.split.open {
			display: block;
		}
		.panel {
			display: none;
			border-left: 0;
			border-top: 1px solid var(--line);
			padding: 1.25rem 0 0;
			margin-top: 1.75rem;
		}
		.split.open .panel {
			display: block;
			opacity: 1;
		}
	}
</style>

<script>
	const split = document.getElementById('split')!;
	const titles = [...split.querySelectorAll<HTMLButtonElement>('[data-open]')];
	const details = [...split.querySelectorAll<HTMLElement>('[data-detail]')];

	function close() {
		split.classList.remove('open');
		titles.forEach((t) => t.setAttribute('aria-expanded', 'false'));
		details.forEach((d) => (d.hidden = true));
	}

	titles.forEach((btn) => {
		btn.setAttribute('aria-expanded', 'false');
		btn.addEventListener('click', () => {
			const i = btn.dataset.open;
			const already = btn.getAttribute('aria-expanded') === 'true';
			close();
			if (already) return; // clicking the open title again closes it
			split.classList.add('open');
			btn.setAttribute('aria-expanded', 'true');
			const detail = details.find((d) => d.dataset.detail === i);
			if (detail) detail.hidden = false;
		});
	});

	split.querySelector('[data-close]')?.addEventListener('click', close);
	window.addEventListener('keydown', (e) => {
		if (e.key === 'Escape') close();
	});
</script>
