---
// Blog — a simple list for now. When you're ready to write real posts,
// we'll upgrade this to Astro "content collections" so each post is just
// a Markdown file. No pressure to write until you feel like it.
import BaseLayout from '../layouts/BaseLayout.astro';

// Placeholder entries — replace with real posts later.
const posts = [
	{
		title: 'Hello, world',
		date: '2026-06-30',
		blurb: 'A first note. Someday this will be a real post.',
		href: '#',
	},
];
---

<BaseLayout title="Blog · Andrea Chen" nav="left">
	<h1>Blog</h1>
	<p class="lede">Occasional thoughts. Quality over quantity.</p>

	<ul class="posts">
		{posts.map((post) => (
			<li>
				<a href={post.href}>
					<span class="post-title">{post.title}</span>
					<time datetime={post.date}>{post.date}</time>
				</a>
				<p>{post.blurb}</p>
			</li>
		))}
	</ul>
</BaseLayout>

<style>
	.posts {
		list-style: none;
		padding: 0;
		margin: 1.5rem 0 0;
	}
	.posts li {
		padding: 1.1rem 0;
		border-bottom: 1px solid var(--line);
	}
	.posts a {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		color: var(--ink);
	}
	.post-title { font-family: var(--font-display); font-size: 1.2rem; }
	.posts time { color: var(--muted); font-size: 0.85rem; white-space: nowrap; }
	.posts p { margin: 0.3rem 0 0; color: var(--muted); font-size: 0.95rem; }
</style>
