---
// Resume / experience — a clean, readable summary.
// Fill in the entries below; add a link to a downloadable PDF if you like.
import BaseLayout from '../layouts/BaseLayout.astro';

const experience = [
	{ role: 'Your role', org: 'Organization', when: '2025 — present', what: 'What you did, briefly.' },
	{ role: 'Earlier role', org: 'Organization', when: '2024 — 2025', what: 'Another line about your work.' },
];

const education = [
	{ school: 'MIT', detail: 'Degree, expected 20XX', when: '' },
];
---

<BaseLayout title="Resume · Andrea Chen" nav="left">
	<h1>Resume</h1>
	<p class="lede">
		A quick overview of what I've worked on.
		{/* Later: <a href="/andrea-resume.pdf">Download PDF →</a> */}
	</p>

	<h2>Experience</h2>
	<div class="entries">
		{experience.map((e) => (
			<div class="entry">
				<div class="entry-head">
					<strong>{e.role}</strong> · <span>{e.org}</span>
					<time>{e.when}</time>
				</div>
				<p>{e.what}</p>
			</div>
		))}
	</div>

	<h2>Education</h2>
	<div class="entries">
		{education.map((e) => (
			<div class="entry">
				<div class="entry-head">
					<strong>{e.school}</strong>
					<time>{e.when}</time>
				</div>
				<p>{e.detail}</p>
			</div>
		))}
	</div>
</BaseLayout>

<style>
	.entries { margin: 0.5rem 0 2rem; }
	.entry { padding: 1rem 0; border-bottom: 1px solid var(--line); }
	.entry-head {
		display: flex;
		align-items: baseline;
		gap: 0.4rem;
		flex-wrap: wrap;
	}
	.entry-head time { margin-left: auto; color: var(--muted); font-size: 0.85rem; }
	.entry p { margin: 0.35rem 0 0; color: var(--muted); }
</style>
